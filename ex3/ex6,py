# ex6 (鉁库棤岽椻棤)

numero = 2
contador = 0

while contador < 10:
    divisores = 0

    # testar todos os numeros ate ao proprio numero
    for x in range(1, numero + 1):
        if numero % x == 0:
            divisores = divisores + 1

    # se tiver exatamente 2 divisores e primo
    if divisores == 2:
        print(numero)
        contador = contador + 1

    numero = numero + 1